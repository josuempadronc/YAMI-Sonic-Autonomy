#:kivy 2.0
#:import Window kivy.core.window.Window

# ── WIDGETS REUTILIZABLES ────────────────────────────────────────────────────

<RuneButton@Button>:
    background_normal: ''
    background_color: 0, 0, 0, 0
    bold: True
    font_size: '13sp'
    color: (0.88, 0.65, 0, 1) if self.state == 'normal' else (1, 1, 1, 1)
    canvas.before:
        Color:
            rgba: (0.35, 0, 0.65, 0.18) if self.state == 'normal' else (0.55, 0, 0.9, 0.38)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [4]
        Color:
            rgba: (0.55, 0, 0.9, 0.75) if self.state == 'normal' else (0.88, 0.65, 0, 1)
        Line:
            rounded_rectangle: [self.x+1, self.y+1, self.width-2, self.height-2, 4]
            width: 1.1

<GoldLabel@Label>:
    color: 0.88, 0.65, 0, 1
    bold: True

<PurpleLabel@Label>:
    color: 0.65, 0.15, 1, 1
    bold: True

# ── LAYOUT PRINCIPAL ─────────────────────────────────────────────────────────

<YAMI_Layout>:
    orientation: 'vertical'
    padding: [14, 18, 14, 12]
    spacing: 9

    canvas.before:
        # Fondo base negro profundo
        Color:
            rgba: 0.03, 0.01, 0.07, 1
        Rectangle:
            pos: self.pos
            size: self.size
        # Viñeta radial morada central
        Color:
            rgba: 0.22, 0, 0.42, 0.18
        Ellipse:
            pos: self.center_x - self.width*0.6, self.center_y - self.height*0.35
            size: self.width*1.2, self.height*0.7
        # Grieta diagonal principal
        Color:
            rgba: 0.55, 0.05, 0.9, 0.15
        Line:
            points: [0, self.height*0.72, self.width*0.38, self.height*0.48, self.width*0.62, self.height*0.55, self.width, self.height*0.35]
            width: 1.8
        # Grieta secundaria
        Color:
            rgba: 0.55, 0.05, 0.9, 0.08
        Line:
            points: [self.width*0.15, self.height, self.width*0.42, self.height*0.5, self.width*0.9, self.height*0.62]
            width: 1.2
        # Borde dorado exterior
        Color:
            rgba: 0.7, 0.48, 0, 0.42
        Line:
            rectangle: [self.x+3, self.y+3, self.width-6, self.height-6]
            width: 1.1
        # Esquinas decorativas
        Color:
            rgba: 0.7, 0.48, 0, 0.65
        Line:
            points: [self.x+3, self.y+18, self.x+3, self.y+3, self.x+18, self.y+3]
            width: 1.5
        Line:
            points: [self.right-18, self.y+3, self.right-3, self.y+3, self.right-3, self.y+18]
            width: 1.5
        Line:
            points: [self.x+3, self.top-18, self.x+3, self.top-3, self.x+18, self.top-3]
            width: 1.5
        Line:
            points: [self.right-18, self.top-3, self.right-3, self.top-3, self.right-3, self.top-18]
            width: 1.5

    # ── TÍTULO ──────────────────────────────────────────────────────────────
    BoxLayout:
        size_hint_y: None
        height: '56dp'
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: 0.5, 0, 0.85, 0.1
            Rectangle:
                pos: self.pos
                size: self.size

        GoldLabel:
            text: 'Y A M I'
            font_size: '28sp'
            letter_spacing: 6
            size_hint_y: 0.58
            canvas.before:
                Color:
                    rgba: 0.55, 0, 0.9, 0.22
                Rectangle:
                    pos: self.pos
                    size: self.size

        BoxLayout:
            size_hint_y: 0.42
            spacing: 6

            PurpleLabel:
                text: '⟁ SONIC'
                font_size: '10sp'
                letter_spacing: 3

            Label:
                text: '✦'
                font_size: '10sp'
                color: 0.7, 0.48, 0, 1
                size_hint_x: None
                width: '14dp'

            PurpleLabel:
                text: 'AUTONOMY ⟁'
                font_size: '10sp'
                letter_spacing: 3

    # ── ORBE ANIMADO (widget Python) ────────────────────────────────────────
    OrbWidget:
        id: orb
        size_hint_y: None
        height: '140dp'

    # ── NOMBRE DE CANCIÓN ────────────────────────────────────────────────────
    BoxLayout:
        size_hint_y: None
        height: '54dp'
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: 0.38, 0, 0.65, 0.12
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [5]
            Color:
                rgba: 0.55, 0, 0.85, 0.5
            Line:
                rounded_rectangle: [self.x+1, self.y+1, self.width-2, self.height-2, 5]
                width: 0.9

        Label:
            id: lbl_cancion
            text: '— SIN CANCIÓN —'
            font_size: '13sp'
            color: 0.95, 0.95, 0.95, 1
            bold: True
            size_hint_y: 0.56
            text_size: self.size
            halign: 'center'
            valign: 'middle'
            shorten: True
            shorten_from: 'right'

        Label:
            id: lbl_status
            text: 'INICIANDO NÚCLEO...'
            font_size: '10sp'
            color: 0.65, 0.15, 1, 1
            size_hint_y: 0.44
            letter_spacing: 1.5

    # ── BARRA DE PROGRESO ────────────────────────────────────────────────────
    BoxLayout:
        size_hint_y: None
        height: '20dp'
        spacing: 6

        Label:
            id: lbl_tiempo
            text: '0:00'
            font_size: '9sp'
            color: 0.7, 0.48, 0, 1
            size_hint_x: None
            width: '30dp'
            bold: True

        ProgressWidget:
            id: prog_widget

        Label:
            id: lbl_duracion
            text: '0:00'
            font_size: '9sp'
            color: 0.7, 0.48, 0, 1
            size_hint_x: None
            width: '30dp'
            bold: True

    # ── VOLUMEN ──────────────────────────────────────────────────────────────
    BoxLayout:
        size_hint_y: None
        height: '28dp'
        spacing: 8

        Label:
            text: '◈'
            font_size: '11sp'
            color: 0.7, 0.48, 0, 0.8
            size_hint_x: None
            width: '18dp'

        Slider:
            id: vol_slider
            min: 0
            max: 1
            value: 0.7
            on_value:
                app.cambiar_volumen(self, self.value)
                lbl_vol_pct.text = f'{int(self.value*100)}%'

        Label:
            id: lbl_vol_pct
            text: '70%'
            font_size: '10sp'
            color: 0.65, 0.15, 1, 1
            size_hint_x: None
            width: '30dp'
            bold: True

    # ── CONTROLES PRINCIPALES ────────────────────────────────────────────────
    BoxLayout:
        size_hint_y: None
        height: '54dp'
        spacing: 7

        RuneButton:
            text: '◄◄'
            font_size: '16sp'
            on_press: app.anterior()

        RuneButton:
            text: '▶'
            font_size: '26sp'
            bold: True
            on_press: app.reproducir()
            canvas.before:
                Color:
                    rgba: (0.45, 0, 0.8, 0.28) if self.state == 'normal' else (0.65, 0, 1, 0.5)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [4]
                Color:
                    rgba: (0.82, 0.58, 0, 1) if self.state == 'normal' else (1, 0.85, 0.2, 1)
                Line:
                    rounded_rectangle: [self.x+1, self.y+1, self.width-2, self.height-2, 4]
                    width: 1.8

        RuneButton:
            text: '||'
            font_size: '18sp'
            bold: True
            on_press: app.pausar()

        RuneButton:
            text: '■'
            font_size: '18sp'
            on_press: app.detener()

        RuneButton:
            text: '▶▶'
            font_size: '16sp'
            on_press: app.siguiente()

    # ── MICRÓFONO / VOZ ──────────────────────────────────────────────────────
    BoxLayout:
        size_hint_y: None
        height: '42dp'
        spacing: 8
        canvas.before:
            Color:
                rgba: 0.3, 0, 0.55, 0.1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [4]
            Color:
                rgba: 0.5, 0, 0.8, 0.3
            Line:
                rounded_rectangle: [self.x+1, self.y+1, self.width-2, self.height-2, 4]
                width: 0.8

        RuneButton:
            id: btn_mic
            text: '( o )  ACTIVAR VOZ'
            font_size: '11sp'
            size_hint_x: 0.48
            letter_spacing: 1
            on_press: app.toggle_microfono()

        BoxLayout:
            orientation: 'vertical'
            size_hint_x: 0.52
            padding: [6, 4]

            Label:
                id: lbl_mic_status
                text: 'MICRÓFONO: INACTIVO'
                font_size: '9sp'
                color: 0.45, 0.45, 0.45, 1
                text_size: self.size
                halign: 'left'
                valign: 'middle'
                bold: True
                letter_spacing: 0.5

            Label:
                id: lbl_mic_comando
                text: 'di: siguiente · pausa · stop'
                font_size: '8sp'
                color: 0.4, 0, 0.6, 0.8
                text_size: self.size
                halign: 'left'
                valign: 'middle'

    # ── BIBLIOTECA ───────────────────────────────────────────────────────────
    BoxLayout:
        size_hint_y: None
        height: '26dp'
        spacing: 6
        canvas.before:
            Color:
                rgba: 0.6, 0.4, 0, 0.1
            Rectangle:
                pos: self.pos
                size: self.size

        GoldLabel:
            id: lbl_biblioteca
            text: 'BIBLIOTECA: — temas'
            font_size: '10sp'
            size_hint_x: 0.65
            text_size: self.size
            halign: 'left'
            valign: 'middle'
            padding_x: 6

        RuneButton:
            text: '⟳  CARGAR'
            font_size: '9sp'
            size_hint_x: 0.35
            letter_spacing: 1
            on_press: app.cargar_biblioteca(0)

    # ── LISTA CANCIONES ──────────────────────────────────────────────────────
    ScrollView:
        do_scroll_x: False
        bar_width: 3
        bar_color: 0.55, 0, 0.85, 0.7
        bar_inactive_color: 0.3, 0, 0.5, 0.4
        canvas.before:
            Color:
                rgba: 0.38, 0, 0.65, 0.08
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [4]
            Color:
                rgba: 0.45, 0, 0.75, 0.32
            Line:
                rounded_rectangle: [self.x+1, self.y+1, self.width-2, self.height-2, 4]
                width: 0.8

        GridLayout:
            id: lista_grid
            cols: 1
            size_hint_y: None
            height: self.minimum_height
            spacing: 2
            padding: [4, 4, 4, 4]
